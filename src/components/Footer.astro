---
import Logo from "./Logo.astro";
---

<footer class="footer">
  <div class="footer__container">
    <div class="footer__logo-bg" aria-hidden="true">
      <Logo />
    </div>
    <div class="footer__content">
      <div class="footer__intro">
        <p class="footer__tagline">
          I look forward<br />
          to welcoming you<br />
          at the studio
        </p>
        <p class="footer__address">
          <strong>Visit Lumi at:</strong> Zeugstraat 8, Gouda
        </p>
      </div>
      <nav class="footer__actions" aria-label="Footer navigation">
        <a href="#" class="btn btn--l btn--light btn--filled">Make a booking</a>
        <a href="mailto:info@studiolumi.nl" class="btn btn--s btn--light"
          >Email</a
        >
        <a href="https://instagram.com/studiolumi" class="btn btn--s btn--light"
          >Instagram</a
        >
        <a href="https://tiktok.com/@studiolumi" class="btn btn--s btn--light"
          >Tiktok</a
        >
      </nav>
    </div>
  </div>
</footer>
